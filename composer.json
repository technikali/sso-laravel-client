{
    "name": "technikali/sso-client",
    "version": "1.0.0",
    "description": "Laravel SSO client package for Bansud LGU single sign-on integration.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "sso", "oauth", "passport", "lgu", "bansud"],
    "authors": [
        {
            "name": "Technikali / Municipality of Bansud IT Division"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "firebase/php-jwt": "^6.0|^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Technikali\\SsoClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Technikali\\SsoClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Technikali\\SsoClient\\SsoClientServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
